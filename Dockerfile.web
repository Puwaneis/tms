FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY vite.config.js index.html components.json jsconfig.json ./
COPY public ./public
COPY src ./src

ENV VITE_API_PROXY_TARGET=http://api:5000

EXPOSE 5173

CMD ["npm", "exec", "vite", "--", "--host", "0.0.0.0", "--port", "5173"]
